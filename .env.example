# ─── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@host:5432/lawhub?schema=public"

# ─── NextAuth ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"
# Full deployed URL — used for auth callbacks and email links
NEXTAUTH_URL="https://lawhub.in"
# Same value exposed to the browser for client-side link generation
NEXT_PUBLIC_APP_URL="https://lawhub.in"
# Server-only alias (preferred in server code over NEXTAUTH_URL)
APP_URL="https://lawhub.in"

# ─── Razorpay ──────────────────────────────────────────────────────────────────
# Dashboard → Settings → API Keys
RAZORPAY_KEY_ID="rzp_live_..."
RAZORPAY_KEY_SECRET="your-razorpay-key-secret"
# Dashboard → Settings → Webhooks → Secret
RAZORPAY_WEBHOOK_SECRET="your-webhook-secret"
# Exposed to browser for Razorpay checkout JS SDK
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_live_..."

# ─── Cloudinary ────────────────────────────────────────────────────────────────
# Server-only (API operations, signed uploads)
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"
# Exposed to browser (cloud name for display, upload preset for unsigned uploads)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloud-name"
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET="your-unsigned-upload-preset"

# ─── AI Provider ───────────────────────────────────────────────────────────────
# "anthropic" for Claude API, "ollama" for local Ollama (development only)
AI_PROVIDER="anthropic"
ANTHROPIC_API_KEY="sk-ant-..."
ANTHROPIC_MODEL="claude-sonnet-4-5"

# Ollama (development only — ignored when AI_PROVIDER=anthropic)
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="qwen2.5:1.5b"

# ─── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="LawHub <noreply@lawhub.in>"

# ─── Rate Limiting (Upstash Redis) ─────────────────────────────────────────────
# Optional — rate limiting degrades gracefully (allows all) when not configured
# Create a free Redis DB at https://console.upstash.com
UPSTASH_REDIS_REST_URL="https://....upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-token"

# ─── Netlify / CI deployment notes ─────────────────────────────────────────────
# All NEXT_PUBLIC_ vars must be set in the Netlify UI under Site Settings → Env Vars
# Never commit .env.local to git
